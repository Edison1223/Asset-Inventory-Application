rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Categories: Anyone can read and write (for now, since no authentication)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true; // Temporarily allow anyone to write
    }

    // Notifications: Anyone can read/write (for now, since no authentication)
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // Deleted Notifications: Anyone can read/write (for now, since no authentication)
    match /deleted_notifications/{documentId} {
      allow read, write: if true;
    }

    // Deleted Notifications by User: Anyone can read/write (for now, since no authentication)
    match /deleted_notifications_by_user/{documentId} {
      allow read, write: if true;
    }

    // Users: Anyone can read/write (for now, since no authentication)
    match /users/{userId} {
      allow read, write: if true;
    }

    // Assets: Anyone can read and write (for now, since no authentication)
    match /assets/{assetId} {
      allow read: if true;
      allow write: if true; // Temporarily allow anyone to write
    }

    // Reports: Anyone can read and write (for now, since no authentication)
    match /reports/{reportId} {
      allow read: if true;
      allow write: if true; // Temporarily allow anyone to write
    }
  }
}